# ─────────────────────────────────────────────────────────────
# Paperclip VM - Environment Variables
# Copy to .env and fill in your values
# NEVER commit this file to Git
# ─────────────────────────────────────────────────────────────

# Required: Authentication secret (min 32 chars, generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=your-secret-here

# Paperclip runtime
NODE_ENV=production
PAPERCLIP_HOME=/home/paper/.paperclip
